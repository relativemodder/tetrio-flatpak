{
    "$schema": "https://json.schemastore.org/flatpak-manifest.json",
    "id": "io.github.relativemodder.tetrio-flatpak",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "base": "org.electronjs.Electron2.BaseApp",
    "base-version": "25.08",
    "command": "tetrio-launcher",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin",
        "env": {
            "CARGO_HOME": "/run/ccache/cargo",
            "CARGO_TARGET_DIR": "/run/ccache/cargo-target"
        },
        "build-args": [
            "--share=network"
        ]
    },
    "finish-args": [
        "--socket=wayland",
        "--socket=x11",
        "--share=ipc",
        "--device=all",
        "--socket=pulseaudio",
        "--share=network",
        "--filesystem=home"
    ],
    "modules": [
        {
            "name": "tetrio",
            "buildsystem": "simple",
            "sources": [
                {
                    "type": "file",
                    "url": "https://tetr.io/about/desktop/builds/10/TETR.IO%20Setup.deb",
                    "sha256": "e3635a6f8d479bbf8dc56fdee7a65b2cf652e9633ef6e1acfc6c6f7055b4abdf",
                    "dest-filename": "tetrio.deb"
                },
                {
                    "type": "file",
                    "path": "io.github.relativemodder.tetrio-flatpak.desktop"
                },
                {
                    "type": "file",
                    "path": "io.github.relativemodder.tetrio-flatpak.metainfo.xml"
                }
            ],
            "build-commands": [
                "ar x tetrio.deb",
                "tar -xf data.tar.xz",
                "mkdir -p /app/share/tetrio",
                "cp -R opt/TETR.IO/* /app/share/tetrio/",
                "rm -f /app/share/tetrio/chrome-sandbox",
                "mkdir -p /app/bin",
                "mkdir -p /app/share/icons/hicolor/256x256/apps",
                "cp usr/share/icons/hicolor/256x256/apps/TETR.IO.png /app/share/icons/hicolor/256x256/apps/io.github.relativemodder.tetrio-flatpak.png",
                "mkdir -p /app/share/applications",
                "install -m 644 io.github.relativemodder.tetrio-flatpak.desktop /app/share/applications/io.github.relativemodder.tetrio-flatpak.desktop",
                "mkdir -p /app/share/metainfo",
                "install -m 644 io.github.relativemodder.tetrio-flatpak.metainfo.xml /app/share/metainfo/io.github.relativemodder.tetrio-flatpak.metainfo.xml"
            ]
        },
        {
            "name": "tetrio-launcher",
            "buildsystem": "simple",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/relativemodder/tetrio-flatpak.git",
                    "branch": "main"
                }
            ],
            "build-commands": [
                "cd tetrio-launcher && cargo build --release --verbose",
                "install -Dm755 /run/ccache/cargo-target/release/tetrio-launcher /app/bin/tetrio-launcher"
            ]
        }
    ]
}